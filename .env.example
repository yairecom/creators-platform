# העתיקי לקובץ .env.local (לפיתוח מקומי) או הגדירי ב-Vercel → Settings → Environment Variables

# מ-Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# סיסמת עורך — גישה מלאה (הוספה/עריכה/מחיקה). אם ריק, האתר פתוח ללא סיסמה
NEXT_PUBLIC_APP_PASSWORD=

# סיסמת צופה — צפייה בלבד (ללא הוספה/עריכה/מחיקה)
NEXT_PUBLIC_VIEWER_PASSWORD=
